{
	"name": "hybrid",
	"version": "1.0.0",
	"type": "module",
	"bin": {
		"hybrid": "./dist/cli.js",
		"hy": "./dist/cli.js"
	},
	"files": [
		"dist",
		"skills",
		"templates"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup && node scripts/bundle-agent.mjs",
		"build:watch": "tsup --watch",
		"clean": "rm -rf .turbo dist",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint --unsafe",
		"lint:fix": "biome lint --write --unsafe",
		"format": "biome format --write",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.38",
		"@google/generative-ai": "^0.21.0",
		"@hono/node-server": "^1.13.5",
		"@hybrd/scheduler": "workspace:*",
		"@hybrd/xmtp": "workspace:*",
		"@hybrid/memory": "workspace:*",
		"@xmtp/agent-sdk": "0.0.14",
		"@xmtp/node-bindings": "^1.9.1",
		"@xmtp/node-sdk": "^4.1.0",
		"ai": "^6.0.0",
		"better-sqlite3": "^11.0.0",
		"chokidar": "^4.0.0",
		"concurrently": "^9.2.1",
		"dotenv": "^16.4.5",
		"hono": "^4.10.8",
		"openai": "^4.0.0",
		"ora": "^8.2.0",
		"picocolors": "^1.1.1",
		"prompts": "^2.4.2",
		"rimraf": "^5.0.10",
		"tsx": "^4.20.5",
		"uint8arrays": "^5.1.0",
		"viem": "^2.46.2",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@config/biome": "workspace:*",
		"@config/tsconfig": "workspace:*",
		"@types/better-sqlite3": "^7.6.13",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/node": "catalog:stack",
		"@types/prompts": "^2.4.9",
		"@vitest/coverage-v8": "^3.2.4",
		"esbuild": "^0.27.3",
		"tsup": "^8.5.0",
		"vitest": "^3.2.4"
	},
	"optionalDependencies": {
		"node-llama-cpp": "^3.0.0",
		"sqlite-vec": "^0.1.0"
	}
}

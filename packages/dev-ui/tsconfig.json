{
	"compilerOptions": {
		"jsx": "react-jsx",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"strict": true,
		"types": ["node"],
		"noEmit": true
	},
	"include": ["src/**/*", "public/**/*"],
	"exclude": ["node_modules", "dist"]
}

{
	"name": "@hybrd/agent",
	"version": "2.1.0",
	"type": "module",
	"main": "./dist/index.cjs",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"require": "./dist/index.cjs"
		},
		"./server": {
			"types": "./src/server/index.ts",
			"import": "./src/server/index.ts",
			"require": "./dist/server/index.cjs"
		}
	},
	"scripts": {
		"build": "node build.mjs",
		"dev": "tsx watch --clear-screen=false src/server/simple.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@mariozechner/pi-coding-agent": "^0.67.68",
		"@chat-adapter/linear": "^4.25.0",
		"@chat-adapter/slack": "^4.25.0",
		"@chat-adapter/discord": "^4.25.0",
		"@chat-adapter/state-pg": "^4.25.0",
		"@google/generative-ai": "^0.21.0",
		"@hono/node-server": "^1.13.5",
		"@hybrd/scheduler": "workspace:*",
		"@hybrd/memory": "workspace:*",
		"@hybrd/types": "workspace:*",
		"ai": "^6.0.0",
		"better-sqlite3": "^11.0.0",
		"chat": "^4.25.0",
		"chokidar": "^4.0.0",
		"dotenv": "^16.4.5",
		"hono": "^4.10.8",
		"openai": "^4.0.0",
		"picocolors": "^1.1.1",
		"viem": "^2.46.2",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^20.0.0",
		"esbuild": "^0.27.3",
		"tsx": "^4.19.3",
		"typescript": "^5.9.2",
		"vitest": "^4.0.18"
	},
	"optionalDependencies": {
		"node-llama-cpp": "^3.0.0",
		"sqlite-vec": "^0.1.0"
	}
}

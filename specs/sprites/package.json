{
	"name": "@hybrid/sprites-vault",
	"version": "1.0.0",
	"description": "Zero-knowledge vault service for Sprites-based agent platform",
	"type": "module",
	"main": "src/vault/vault-service.ts",
	"scripts": {
		"start": "npm run build && node dist/vault/vault-service.js",
		"dev": "tsx src/vault/vault-service.ts",
		"dev:agent": "tsx src/agent/agent.ts",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:integration": "vitest run --config vitest.integration.config.ts",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"docker:build:vault": "docker build -t hybrid/vault:latest -f Dockerfile.vault .",
		"docker:build:agent": "docker build -t hybrid/agent:latest -f Dockerfile.agent .",
		"docker:build:all": "npm run docker:build:vault && npm run docker:build:agent",
		"docker:up": "docker-compose up -d",
		"docker:down": "docker-compose down",
		"docker:logs": "docker-compose logs -f",
		"lint": "eslint src --ext .ts",
		"format": "prettier --write \"src/**/*.ts\""
	},
	"dependencies": {
		"express": "^4.18.2",
		"yaml": "^2.3.4"
	},
	"devDependencies": {
		"@fly/sprites": "^0.0.1",
		"@types/express": "^4.17.21",
		"@types/node": "^20.10.0",
		"tsx": "^4.7.0",
		"typescript": "^5.3.0",
		"vitest": "^1.2.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}

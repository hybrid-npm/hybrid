{
  "$schema": "https://railway.app/schema.json",
  "name": "hybrid-agent",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "environmentVariables": {
    "AGENT_PORT": "4100"
  }
}

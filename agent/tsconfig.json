{
	"extends": "@config/tsconfig/base.json",
	"compilerOptions": {
		"lib": ["ES2022"],
		"types": ["@cloudflare/workers-types", "node", "bun-types"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}

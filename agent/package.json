{
	"name": "@hybrd/agent",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "node build.mjs",
		"dev": "concurrently -n agent,xmtp -c blue,green \"pnpm watch:container\" \"pnpm watch:sidecar\"",
		"dev:container": "tsx src/server/index.ts",
		"dev:sidecar": "tsx src/sidecar.ts",
		"watch:container": "nodemon --config nodemon.container.json",
		"watch:sidecar": "nodemon --config nodemon.sidecar.json",
		"test:agent": "tsx src/test-agent.ts",
		"test:openrouter": "tsx src/test-openrouter.ts",
		"deploy": "wrangler deploy",
		"typecheck": "tsc --noEmit",
		"register": "tsx ../packages/xmtp/scripts/register-wallet.ts"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.38",
		"@cloudflare/sandbox": "^0.7.1",
		"@hono/node-server": "^1.13.5",
		"@hybrd/types": "workspace:*",
		"@hybrd/utils": "workspace:*",
		"@hybrd/xmtp": "workspace:*",
		"@xmtp/agent-sdk": "0.0.14",
		"ai": "^6.0.0",
		"dotenv": "^16.4.5",
		"hono": "^4.10.8",
		"hybrid": "workspace:*",
		"viem": "^2.46.2"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250214.0",
		"@config/tsconfig": "workspace:*",
		"@types/node": "catalog:stack",
		"concurrently": "^9.2.1",
		"nodemon": "^3.1.14",
		"tsx": "^4.19.3",
		"typescript": "^5.9.2",
		"wrangler": "^4.0.0"
	}
}
